# -- Django ----------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_50_CHARS
DEBUG=False
ALLOWED_HOSTS=YOUR_DOMAIN.COM,www.YOUR_DOMAIN.COM,YOUR_SERVER_IP

# -- Database ---------------------------------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=carrent_db
DB_USER=carrent_user
DB_PASSWORD=STRONG_DB_PASSWORD_HERE
DB_HOST=db
DB_PORT=5432

# -- Redis -------------------------------------------------
REDIS_PASSWORD=STRONG_REDIS_PASSWORD_HERE
REDIS_URL=redis://:STRONG_REDIS_PASSWORD_HERE@redis:6379/0

# -- AI APIs -----------------------------------------------
OPENAI_API_KEY=sk-...your-openai-key...
ANTHROPIC_API_KEY=sk-ant-...your-claude-key...

# -- Instagram / Meta --------------------------------------
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_VERIFY_TOKEN=your_random_verify_token_string

# -- Frontend ----------------------------------------------
NEXT_PUBLIC_API_URL=https://YOUR_DOMAIN.COM/api
NEXT_PUBLIC_WS_URL=wss://YOUR_DOMAIN.COM/ws

# -- Email -------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=CarRent AI <your@gmail.com>

# -- Telegram Notifications --------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# -- CORS --------------------------------------------------
CORS_ALLOWED_ORIGINS=https://YOUR_DOMAIN.COM
